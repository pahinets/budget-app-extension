{
  "manifest_version": 3,
  "name": "Реєстр Часу / Time Ledger",
  "version": "2.3.0",
  "description": "Блокує розважальні сайти після перевищення встановленого денного ліміту",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Реєстр Часу"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["compat.js", "content.js"],
      "run_at": "document_start"
    }
  ]
}